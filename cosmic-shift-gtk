MENU_OPEN, MENU_SEP, MENU_QUIT = 1, 2, 3


class TrayIcon:
    """System tray icon via the StatusNotifierItem D-Bus protocol.

    GTK4 has no tray support of its own; COSMIC's Status Area applet (and
    most other trays) host org.kde.StatusNotifierItem, with the context
    menu served over com.canonical.dbusmenu.
    """

    WATCHER = "org.kde.StatusNotifierWatcher"

    def __init__(self, app):
        self.app = app
        self.active = False
        self._held = False
        self.bus = Gio.bus_get_sync(Gio.BusType.SESSION, None)
        self.bus_name = f"org.kde.StatusNotifierItem-{os.getpid()}-1"
        sni = Gio.DBusNodeInfo.new_for_xml(SNI_XML).interfaces[0]
        menu = Gio.DBusNodeInfo.new_for_xml(DBUSMENU_XML).interfaces[0]
        self.bus.register_object("/StatusNotifierItem", sni,
                                 self._sni_call, self._sni_get, None)
        self.bus.register_object("/MenuBar", menu,
                                 self._menu_call, self._menu_get, None)
        Gio.bus_own_name_on_connection(
            self.bus, self.bus_name, Gio.BusNameOwnerFlags.NONE, None, None)
        self._register()
        # re-register if the tray host goes away and comes back
        Gio.bus_watch_name(
            Gio.BusType.SESSION, self.WATCHER, Gio.BusNameWatcherFlags.NONE,
            lambda *a: self._register(),
            lambda *a: setattr(self, "active", False))

    def _register(self):
        if self.active:
            return
        try:
            self.bus.call_sync(
                self.WATCHER, "/StatusNotifierWatcher", self.WATCHER,
                "RegisterStatusNotifierItem",
                GLib.Variant("(s)", (self.bus_name,)),
                None, Gio.DBusCallFlags.NONE, 2000, None)
            self.active = True
            if not self._held:
                self._held = True
                self.app.hold()  # keep running with the window hidden
        except GLib.Error:
            self.active = False

    # --- org.kde.StatusNotifierItem ----------------------------------------

    def _sni_get(self, _conn, _sender, _path, _iface, prop):
        return {
            "Category": GLib.Variant("s", "ApplicationStatus"),
            "Id": GLib.Variant("s", APP_ID),
            "Title": GLib.Variant("s", "Cosmic Shift"),
            "Status": GLib.Variant("s", "Active"),
            "IconName": GLib.Variant("s", APP_ID),
            "IconThemePath": GLib.Variant("s", ""),
            "Menu": GLib.Variant("o", "/MenuBar"),
            "ItemIsMenu": GLib.Variant("b", False),
        }.get(prop)

    def _sni_call(self, _conn, _sender, _path, _iface, method, _params,
                  invocation):
        if method == "Activate":
            self.app.toggle_window()
        invocation.return_value(None)

    # --- com.canonical.dbusmenu ---------------------------------------------

    def _item_props(self, item_id):
        if item_id == MENU_OPEN:
            return {"label": GLib.Variant("s", "Open Cosmic Shift")}
        if item_id == MENU_SEP:
            return {"type": GLib.Variant("s", "separator")}
        if item_id == MENU_QUIT:
            return {"label": GLib.Variant("s", "Quit")}
        return {"children-display": GLib.Variant("s", "submenu")}

    def _menu_get(self, _conn, _sender, _path, _iface, prop):
        return {
            "Version": GLib.Variant("u", 3),
            "Status": GLib.Variant("s", "normal"),
            "TextDirection": GLib.Variant("s", "ltr"),
            "IconThemePath": GLib.Variant("as", []),
        }.get(prop)

    def _menu_call(self, _conn, _sender, _path, _iface, method, params,
                   invocation):
        if method == "GetLayout":
            children = [
                GLib.Variant("v", GLib.Variant(
                    "(ia{sv}av)", (i, self._item_props(i), [])))
                for i in (MENU_OPEN, MENU_SEP, MENU_QUIT)]
            invocation.return_value(GLib.Variant(
                "(u(ia{sv}av))", (1, (0, self._item_props(0), children))))
        elif method == "GetGroupProperties":
            ids = params.unpack()[0] or [0, MENU_OPEN, MENU_SEP, MENU_QUIT]
            invocation.return_value(GLib.Variant(
                "(a(ia{sv}))", ([(i, self._item_props(i)) for i in ids],)))
        elif method == "GetProperty":
            item_id, name = params.unpack()
            value = self._item_props(item_id).get(name, GLib.Variant("s", ""))
            invocation.return_value(GLib.Variant("(v)", (value,)))
        elif method == "Event":
            item_id, event = params.unpack()[:2]
            if event == "clicked":
                if item_id == MENU_OPEN:
                    self.app.toggle_window(show=True)
                elif item_id == MENU_QUIT:
                    self.app.quit_from_tray()
            invocation.return_value(None)
        elif method == "AboutToShow":
            invocation.return_value(GLib.Variant("(b)", (False,)))
        else:
            invocation.return_value(None)


class Window(Gtk.ApplicationWindow):
    def __init__(self, app, ctl, conf):
        super().__init__(application=app, title="Cosmic Shift")
        self.ctl = ctl
        self.conf = conf
        self._loading = True
        self._debounce = 0
        self.set_default_size(440, -1)
        self.set_resizable(False)

        header = Gtk.HeaderBar()
        self.enable_switch = Gtk.Switch(
            valign=Gtk.Align.CENTER,
            active=conf.getboolean("cosmic-shift", "enabled"))
        self.enable_switch.connect("notify::active", self.on_enable)
        box = Gtk.Box(spacing=8)
        box.append(Gtk.Label(label="Enabled"))
        box.append(self.enable_switch)
        header.pack_start(box)
        self.set_titlebar(header)

        grid = Gtk.Grid(row_spacing=10, column_spacing=12,
                        margin_top=18, margin_bottom=18,
                        margin_start=18, margin_end=18)
        self.set_child(grid)

        self.temp_scale = self._add_scale(
            grid, 0, "Temperature",
            1000, 6500, 50, conf.getfloat("cosmic-shift", "temp"),
            marks=[(2700, "2700 K"), (3400, "3400 K"), (4500, "4500 K"),
                   (6500, "6500 K")],
            fmt=lambda v: f"{int(v)} K")

        self.tint_scale = self._add_scale(
            grid, 2, "Tint",
            0, 100, 1, conf.getfloat("cosmic-shift", "tint") * 100,
            marks=[(2, "2%"), (50, "50%"), (100, "100%")],
            fmt=lambda v: f"{int(v)}%")

        self.bright_scale = self._add_scale(
            grid, 4, "Brightness",
            10, 100, 1, conf.getfloat("cosmic-shift", "brightness") * 100,
            marks=[(50, "50%"), (100, "100%")],
            fmt=lambda v: f"{int(v)}%")

        hint = Gtk.Label(
            label="Lower tint = less yellow cast, more dimming.\n"
                  "Lower temperature = warmer and darker.",
            wrap=True, justify=Gtk.Justification.CENTER)
        hint.add_css_class("dim-label")
        grid.attach(hint, 0, 6, 2, 1)

        auto_box = Gtk.Box(spacing=8, halign=Gtk.Align.CENTER, margin_top=6)
        self.autostart_switch = Gtk.Switch(
            valign=Gtk.Align.CENTER,
            active=conf.getboolean("cosmic-shift", "autostart"))
        self.autostart_switch.connect("notify::active", self.on_autostart)
        auto_box.append(Gtk.Label(label="Start at login"))
        auto_box.append(self.autostart_switch)
        grid.attach(auto_box, 0, 7, 2, 1)

        credit = Gtk.Label(label="Created by: Seth Walton", margin_top=10)
        credit.add_css_class("dim-label")
        credit.add_css_class("caption")
        grid.attach(credit, 0, 8, 2, 1)

        self.connect("close-request", self.on_close)
        self._loading = False
        if self.enable_switch.get_active():
            self.ctl.start(*self.values())

    def _add_scale(self, grid, row, label, lo, hi, step, value, marks, fmt):
        lbl = Gtk.Label(label=label, halign=Gtk.Align.START)
        grid.attach(lbl, 0, row, 2, 1)
        scale = Gtk.Scale.new_with_range(
            Gtk.Orientation.HORIZONTAL, lo, hi, step)
        scale.set_value(value)
        scale.set_hexpand(True)
        scale.set_draw_value(True)
        scale.set_value_pos(Gtk.PositionType.RIGHT)
        scale.set_format_value_func(lambda s, v: fmt(v))
        for mval, mtext in marks:
            scale.add_mark(mval, Gtk.PositionType.BOTTOM, mtext)
        scale.connect("value-changed", self.on_slider)
        grid.attach(scale, 0, row + 1, 2, 1)
        return scale

    def values(self):
        return (self.temp_scale.get_value(),
                self.tint_scale.get_value() / 100.0,
                self.bright_scale.get_value() / 100.0)

    # --- signal handlers -------------------------------------------------

    def on_slider(self, _scale):
        if self._loading:
            return
        if self._debounce:
            GLib.source_remove(self._debounce)
        self._debounce = GLib.timeout_add(100, self._push)

    def _push(self):
        self._debounce = 0
        if self.enable_switch.get_active():
            if not self.ctl.send(*self.values()):
                self.ctl.start(*self.values())
        return GLib.SOURCE_REMOVE

    def on_enable(self, switch, _pspec):
        if self._loading:
            return
        if switch.get_active():
            self.ctl.start(*self.values())
        else:
            self.ctl.stop()

    def on_autostart(self, switch, _pspec):
        if self._loading:
            return
        if switch.get_active():
            self.write_unit()
            subprocess.run(["systemctl", "--user", "enable",
                            "cosmic-shift"], capture_output=True)
        else:
            subprocess.run(["systemctl", "--user", "disable",
                            "cosmic-shift"], capture_output=True)

    def on_close(self, _win):
        self.save()
        app = self.get_application()
        if app.tray is not None and app.tray.active:
            # keep running in the tray; the managed daemon stays attached
            self.set_visible(False)
            return True
        if self.enable_switch.get_active():
            # keep the shift active after the window goes away
            self.ctl.detach(*self.values())
        else:
            self.ctl.stop()
        return False

    # --- persistence ------------------------------------------------------

    def save(self):
        temp, tint, brightness = self.values()
        sec = self.conf["cosmic-shift"]
        sec["enabled"] = str(self.enable_switch.get_active()).lower()
        sec["temp"] = str(int(temp))
        sec["tint"] = f"{tint:.3f}"
        sec["brightness"] = f"{brightness:.3f}"
        sec["autostart"] = str(self.autostart_switch.get_active()).lower()
        os.makedirs(os.path.dirname(CONF_PATH), exist_ok=True)
        with open(CONF_PATH, "w") as f:
            self.conf.write(f)
        if self.autostart_switch.get_active():
            self.write_unit()

    def write_unit(self):
        temp, tint, brightness = self.values()
        exec_start = (f"{self.ctl.daemon_path} -t {int(temp)} "
                      f"-s {tint:.3f} -b {brightness:.3f}")
        os.makedirs(os.path.dirname(UNIT_PATH), exist_ok=True)
        with open(UNIT_PATH, "w") as f:
            f.write(UNIT_TEMPLATE.format(exec_start=exec_start))
        subprocess.run(["systemctl", "--user", "daemon-reload"],
                       capture_output=True)


class App(Gtk.Application):
    def __init__(self):
        super().__init__(application_id=APP_ID)
        self.win = None
        self.tray = None

    def toggle_window(self, show=False):
        if self.win is None:
            return
        if show or not self.win.is_visible():
            self.win.present()
        else:
            self.win.set_visible(False)

    def quit_from_tray(self):
        if self.win is not None:
            self.win.save()
            if self.win.enable_switch.get_active():
                self.win.ctl.detach(*self.win.values())
            else:
                self.win.ctl.stop()
        self.quit()

    def do_activate(self):
        if self.win is not None:
            self.win.present()
            return

        daemon = find_daemon()
        if daemon is None:
            dlg = Gtk.MessageDialog(
                text="cosmic-shift binary not found",
                secondary_text="Run 'make install PREFIX=~/.local' first.",
                buttons=Gtk.ButtonsType.CLOSE)
            dlg.connect("response", lambda d, r: self.quit())
            dlg.present()
            return

        # Take over from any daemon already running (systemd unit, detached
        # instance from a previous GUI session, or a manual CLI run).
        subprocess.run(["systemctl", "--user", "stop", "cosmic-shift"],
                       capture_output=True)
        subprocess.run(["pkill", "-x", "cosmic-shift"], capture_output=True)

        conf = configparser.ConfigParser()
        conf["cosmic-shift"] = dict(DEFAULTS)
        conf.read(CONF_PATH)

        self.win = Window(self, Controller(daemon), conf)
        self.tray = TrayIcon(self)
        self.win.present()


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    sys.exit(App().run(sys.argv))
